generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Note: SQLite does not support native enum types.
// Enum values are stored as plain strings and validated at the Zod layer.

// ─── Auth.js (NextAuth v5) required models ───────────────────────────────────

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  isAdmin       Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt @default(now())

  accounts Account[]
  sessions Session[]
  members  Member[]

  @@map("user")
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("account")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_token")
}

// ─── Application models ───────────────────────────────────────────────────────

model Member {
  id                 String   @id @default(uuid())
  userId             String
  name               String
  email              String   @unique
  skillLevel         String   // "Junior" | "Mid-level" | "Senior" | "Lead"
  primaryTeam        String   // "Backend" | "Frontend" | etc.
  otherTeamName      String?
  shift              String   // "Day Shift" | "Afternoon Shift" | "Night Shift"
  weeklySchedule     Json     // { mon, tue, wed, thu, fri, sat, sun }
  activeProjectCount Int      @default(0)
  updatedAt          DateTime @updatedAt @default(now())

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamLinks TeamMemberLink[]

  @@map("member")
}

model GeneratedTeam {
  id        String   @id @default(uuid())
  name      String
  sessionId String
  presetId  String?
  createdAt DateTime @default(now())

  memberLinks TeamMemberLink[]

  @@index([sessionId])
  @@map("generated_team")
}

model TeamMemberLink {
  teamId          String
  memberId        String
  manuallySwapped Boolean @default(false)

  team   GeneratedTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)
  member Member        @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@id([teamId, memberId])
  @@map("team_member_link")
}

model Preset {
  id        String   @id @default(uuid())
  name      String   @unique
  config    Json     // RandomizerConfig snapshot
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt @default(now())

  @@map("preset")
}
