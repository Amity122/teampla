# Copy this file to .env and fill in values.
# .env is gitignored — never commit real secrets.

# ── Database ──────────────────────────────────────────────────────────────────
# Local development (SQLite — file auto-created on `npm run db:push`)
DATABASE_URL="file:./prisma/dev.db"

# --- Production options (pick one, set in Vercel dashboard) ---

# Option A: Turso (libSQL — SQLite-compatible, recommended for Vercel MVP)
# Requires: npm install @prisma/adapter-libsql @libsql/client
# Update prisma/schema.prisma: provider = "libsql"
# DATABASE_URL="libsql://[your-db].turso.io?authToken=[your-token]"

# Option B: Supabase / any PostgreSQL
# Update prisma/schema.prisma: provider = "postgresql"
# DATABASE_URL="postgresql://user:password@host:5432/dbname"

# ── Auth (NextAuth v5 / Auth.js) ──────────────────────────────────────────────
# Generate with: npx auth secret
AUTH_SECRET=""

# From Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client
# Authorized redirect URIs:
#   Local:      http://localhost:3000/api/auth/callback/google
#   Production: https://your-domain.com/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Comma-separated emails that get admin access on first sign-in
ADMIN_EMAILS="admin@yourcompany.com"
