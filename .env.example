# Copy this file to .env and fill in the values.
# .env is gitignored — never commit real secrets.

# Local development (SQLite — file is created automatically)
DATABASE_URL=sqlite:///./teampla.db

# --- Production options (pick one) ---

# Option A: Turso (libSQL — SQLite-compatible, recommended for Vercel MVP)
# Requires: uv add sqlalchemy-libsql
# DATABASE_URL=libsql://[your-db].turso.io?authToken=[your-token]

# Option B: Supabase / any PostgreSQL
# Requires: uv add psycopg2-binary
# DATABASE_URL=postgresql://user:password@host:5432/dbname
