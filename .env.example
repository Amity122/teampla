# Copy this file to .env and fill in values.
# .env is gitignored — never commit real secrets.

# ── Database ──────────────────────────────────────────────────────────────────
# Local development (SQLite — file auto-created on `npm run db:push`)
DATABASE_URL="file:./prisma/dev.db"

# Production: Turso (set both in Vercel dashboard)
# TURSO_AUTH_TOKEN is what switches Prisma to use the libsql adapter.
# DATABASE_URL="libsql://your-db.turso.io"
# TURSO_AUTH_TOKEN="your-turso-auth-token"

# ── Auth (NextAuth v5 / Auth.js) ──────────────────────────────────────────────
# Generate with: npx auth secret
AUTH_SECRET=""

# From Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client
# Authorized redirect URIs:
#   Local:      http://localhost:3000/api/auth/callback/google
#   Production: https://your-domain.com/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
